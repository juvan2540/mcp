{
    "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
    "name": "io.github.markdownlm/mcp",
    "title": "MarkdownLM MCP Server",
    "description": "AI Agent Memory & Validation Layer — connect Cursor and Claude to your team rules and patterns.",
    "repository": {
        "url": "https://github.com/markdownlm/mcp",
        "source": "github"
    },
    "websiteUrl": "https://markdownlm.com",
    "version": "3.0.0",
    "packages": [
        {
            "registryType": "npm",
            "identifier": "markdownlm-mcp",
            "version": "3.0.0",
            "transport": {
                "type": "stdio"
            },
            "runtimeArguments": [
                {
                    "type": "positional",
                    "value": "-y"
                },
                {
                    "type": "positional",
                    "value": "markdownlm-mcp"
                }
            ],
            "runtimeHint": "npx",
            "environmentVariables": [
                {
                    "name": "MARKDOWNLM_API_KEY",
                    "description": "Your MarkdownLM API key. Get it from Settings → API & MCP at markdownlm.com.",
                    "isRequired": true,
                    "isSecret": true,
                    "format": "string"
                },
                {
                    "name": "MARKDOWNLM_API_URL",
                    "description": "Override base URL for self-hosted or staging deployments. Defaults to https://markdownlm.com.",
                    "isRequired": false,
                    "isSecret": false,
                    "format": "string"
                }
            ]
        }
    ]
}